@page "/quiz"
@using L26Exercise.Services
@inject QuizState quiz

<h3>Quiz</h3>

@if (currentIndex < questions.Count)
{

    <p>@questions[currentIndex].Question</p>
    <input type="text" @bind="userAnswer" />
    <button @onclick="submitAnser">Submit Answer</button>
    <p>@feedback</p>
}
else
{
    <p>Quiz complete! Navigate to Results to see your score.</p>
    <NavLink class="nav-link" href="quiz-results">
        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Results
    </NavLink>
}
@code {
    private List<(string Question, string Answer)> questions = new()
{
    ("What is the capital of France?", "Paris"),
    ("How many sides does a hexagon have?", "6"),
    ("What is the chemical symbol for water?", "H2O"),
    ("What planet is closest to the Sun?", "Mercury"),
    ("What is 12 x 12?", "144")
};
    int currentIndex = 0;
    string? userAnswer = null;
    string? feedback = null;

    private void submitAnser()
    {
        bool isCorrect = (userAnswer == questions[currentIndex].Answer);
        quiz.RecordAnswer(isCorrect);
        if (isCorrect)
            feedback = "Correct!";
        else feedback = $"Incorrect. The answer was {questions[currentIndex].Answer}";
        
        currentIndex++;
        userAnswer = null;
    }
}
